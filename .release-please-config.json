{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "packages": {
    "sim/hw-model": {
      "component": "hw-model",
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md"
    },
    "firmware": {
      "component": "firmware",
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md"
    },
    "kernel": {
      "component": "kernel",
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md"
    },
    "runtime/userlib": {
      "component": "userlib",
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md"
    },
    "runtime/appframework": {
      "component": "appframework",
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md"
    },
    "server": {
      "component": "server",
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md"
    },
    "sdk": {
      "component": "sdk",
      "release-type": "python",
      "changelog-path": "CHANGELOG.md"
    },
