#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
# Pre-commit hook: run clang-tidy for staged C++ source files.
# Install once with: git config core.hooksPath .githooks
set -euo pipefail

# git hooks are invoked with a minimal PATH; restore common tool locations.
export PATH="/usr/local/bin:${HOME}/.local/bin:${HOME}/.cargo/bin:${PATH}"

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Only run clang-tidy if it is installed.
if ! command -v clang-tidy &>/dev/null; then
    echo "[pre-commit] clang-tidy not found — skipping C++ lint" >&2
    exit 0
fi

# Collect staged C++ translation units (not headers — headers have no
# standalone entry in compile_commands.json and are linted transitively).
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(cpp|cxx|cc)$' || true)
if [[ -z "$STAGED" ]]; then
    exit 0
fi

DEFAULT_DB="${REPO_ROOT}/build/dev/compile_commands.json"
if [[ ! -f "$DEFAULT_DB" ]]; then
    echo "[pre-commit] compile_commands.json not found at ${DEFAULT_DB}" >&2
    echo "[pre-commit] Run: cmake --preset dev first" >&2
    exit 0
fi

# Build a list of all available compile databases (dev first, then others).
ALL_DBS=()
for db in "${REPO_ROOT}/build/dev/compile_commands.json" \
          "${REPO_ROOT}"/build/*/compile_commands.json; do
    [[ -f "$db" ]] && ALL_DBS+=("$db")
done

FAILED=()
while IFS= read -r file; do
    abs="${REPO_ROOT}/${file}"
    echo "[pre-commit] clang-tidy: ${file}"

    # Find the first compile database that knows about this file.
    db_for_file=""
    for db in "${ALL_DBS[@]}"; do
        if grep -qF "\"file\": \"${abs}\"" "$db" 2>/dev/null; then
            db_for_file="$db"
            break
        fi
    done

    if [[ -z "$db_for_file" ]]; then
        echo "[pre-commit] skip: ${file} not in any compile_commands.json" >&2
        continue
    fi

    if ! clang-tidy -p "$db_for_file" "$abs" 2>/dev/null; then
        FAILED+=("$file")
    fi
done <<< "$STAGED"

if [[ ${#FAILED[@]} -ne 0 ]]; then
    echo ""
    echo "[pre-commit] ✗ clang-tidy failed for: ${FAILED[*]}" >&2
    exit 1
fi

echo "[pre-commit] ✓ C++ lint passed."
